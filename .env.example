# Optional: replace the rule-based mock extractor with a real LLM provider later.
LLM_API_KEY=
LLM_MODEL=

# Demo default is "*". In production use explicit origins, separated by comma.
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Optional: enable real Feishu Bitable sync.
# If these are empty, /api/leads/{id}/sync/feishu uses the built-in mock sync.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
